# ---- Server ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# LOG_PRETTY: human-readable log lines instead of raw JSON. On here so the
# container's output is readable; unset it in a real deployment to emit JSON
# for a log aggregator.
LOG_PRETTY=true

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=customer_portal

# ---- Auth (JWT) ----
# The value below works out of the box for local/demo use (it satisfies the
# 16+ char minimum). For a real deployment, replace it with a long random
# string, e.g. `openssl rand -hex 32`.
JWT_SECRET=local-dev-secret-not-for-production-use
JWT_EXPIRES_IN=1h

# ---- Admin seed account (used by `npm run seed`) ----
ADMIN_EMAIL=admin@portal.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Portal Admin

# ---- Cache ----
# CACHE_DRIVER: "memory" (default, no external service) or "redis"
CACHE_DRIVER=memory
CACHE_TTL_SECONDS=60
REDIS_URL=redis://localhost:6379

# ---- Email (Nodemailer) ----
# EMAIL_DRIVER: "smtp" (default) delivers to the Mailpit container that
# `docker compose up` starts for you — open the inbox at http://localhost:8025
# to watch order emails arrive. No account and no internet needed.
# Use "console" instead to log messages rather than send them (handy when
# running on the host with no SMTP server around).
#
# SMTP_HOST is `localhost` here for host-run `npm run dev`; compose overrides it
# to the `mailpit` service name inside the container network.
#
# For a real service (Mailtrap, SendGrid, Gmail), put its host/port/credentials
# here and set SMTP_SECURE=true if it requires TLS.
EMAIL_DRIVER=smtp
EMAIL_FROM="Customer Portal <no-reply@portal.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
