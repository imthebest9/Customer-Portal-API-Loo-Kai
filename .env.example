# ---- Server ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- Database (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=customer_portal

# ---- Auth (JWT) ----
# Use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# ---- Admin seed account (used by `npm run seed`) ----
ADMIN_EMAIL=admin@portal.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Portal Admin

# ---- Cache ----
# CACHE_DRIVER: "memory" (default, no external service) or "redis"
CACHE_DRIVER=memory
CACHE_TTL_SECONDS=60
REDIS_URL=redis://localhost:6379

# ---- Email (Nodemailer) ----
# EMAIL_DRIVER: "console" (dev, logs instead of sending) or "smtp"
EMAIL_DRIVER=console
EMAIL_FROM="Customer Portal <no-reply@portal.local>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
